{
  "name": "@ansvar/india-bis-standards-mcp",
  "version": "0.1.0",
  "mcpName": "in.ansvar/india-bis-standards-mcp",
  "description": "Bureau of Indian Standards (BIS) IS standards catalog for IT and cybersecurity — metadata, ISO equivalents, IT Act rules",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "india-bis-standards-mcp": "dist/src/index.js"
  },
  "files": [
    "dist",
    "server.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ansvar-Systems/india-bis-standards-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Ansvar-Systems/india-bis-standards-mcp/issues"
  },
  "homepage": "https://github.com/Ansvar-Systems/india-bis-standards-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "bis",
    "india",
    "standards",
    "it-security",
    "compliance",
    "ansvar"
  ],
  "author": "Ansvar Systems AB <hello@ansvar.ai>",
  "license": "BSL-1.1",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/http-server.ts",
    "start": "node dist/src/http-server.js",
    "seed": "npx tsx scripts/seed-sample.ts",
    "ingest": "npx tsx scripts/ingest.ts",
    "ingest:fetch": "npx tsx scripts/ingest-fetch.ts",
    "ingest:diff": "npx tsx scripts/ingest-diff.ts",
    "build:db": "npx tsx scripts/build-db.ts",
    "coverage:update": "npx tsx scripts/update-coverage.ts",
    "freshness:check": "npx tsx scripts/check-freshness.ts",
    "ingest:full": "npm run ingest:fetch && npm run build:db && npm run coverage:update",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:contract": "vitest run --config vitest.contract.config.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "playwright": "^1.59.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^9.4.3",
    "cheerio": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.22.4"
  }
}
